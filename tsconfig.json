{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist/ts",
    "rootDir": "src",
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "**/*.example.ts",
    "**/*.example.*.ts",
    "**/*.example.tsx",
    "**/*.example.*.tsx"
  ]
}
